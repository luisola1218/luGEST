# MODELO PARA UM POSTO CLIENTE
# Copiar para lugest.env em cada posto e ajustar o IP/NOME do servidor.

LUGEST_DB_HOST=192.168.1.100
LUGEST_DB_PORT=3306
LUGEST_DB_USER=lugest_user
LUGEST_DB_PASS=trocar-password
LUGEST_DB_NAME=lugest

# Tem de apontar para a mesma pasta partilhada do servidor.
LUGEST_SHARED_STORAGE_ROOT=\\SERVIDOR\LuGEST\Ficheiros

# O OWNER deve ser igual em todos os postos do mesmo cliente.
# A password do OWNER segue em hash e nao revela a password real.
# Mantem a password real do OWNER fora desta pasta.
LUGEST_OWNER_USERNAME=lugestowner
LUGEST_OWNER_PASSWORD=pbkdf2_sha256$260000$a60XPwQWfif6QNuSa2Y-rg$6jAUX6Bofypwjv9LZwsanTIWpQZKdIy0FoLzjXmscpU

# Multi-posto: 0 permite usar a licença/trial ativada no servidor/base de dados.
LUGEST_TRIAL_BIND_DEVICE=0

# Nao uses bootstrap em ambiente normal multi-posto.
# LUGEST_BOOTSTRAP_ADMIN_USERNAME=
# LUGEST_BOOTSTRAP_ADMIN_PASSWORD=
# LUGEST_BOOTSTRAP_ADMIN_ROLE=
