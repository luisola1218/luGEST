# Copiar para lugest.env e ajustar para a empresa/servidor alvo.
LUGEST_DB_HOST=127.0.0.1
LUGEST_DB_PORT=3306
LUGEST_DB_USER=lugest_user
LUGEST_DB_PASS=trocar-password
LUGEST_DB_NAME=lugest

# Login do proprietario/vendedor para reautorizar trials expirados.
# A password do OWNER segue em hash e nao revela a password real.
# Mantem a password real fora desta pasta e entrega-a apenas a quem deve autorizar trials.
# O OWNER nao substitui o administrador local da aplicacao.
# Para criar/repor o admin local usa o script Desktop App\Criar Administrador Inicial.bat
# ou Desktop App\Repor Password Administrador.bat na instalacao final.
LUGEST_OWNER_USERNAME=lugestowner
LUGEST_OWNER_PASSWORD=pbkdf2_sha256$260000$a60XPwQWfif6QNuSa2Y-rg$6jAUX6Bofypwjv9LZwsanTIWpQZKdIy0FoLzjXmscpU

# Opcional: bootstrap de contingencia para instalacoes sem qualquer utilizador local.
# So e aplicado quando a tabela users estiver vazia. Numa instalacao normal,
# prefere sempre os scripts de criacao/reposicao de administrador.
# LUGEST_BOOTSTRAP_ADMIN_USERNAME=admin_inicial
# LUGEST_BOOTSTRAP_ADMIN_PASSWORD=PasswordMuitoForte#2026
# LUGEST_BOOTSTRAP_ADMIN_ROLE=Admin

# Opcional mas recomendado em ambientes multi-posto:
# define uma pasta partilhada (UNC) para centralizar desenhos, PDFs de faturas,
# comprovativos e outros anexos. Assim todos os postos abrem os mesmos ficheiros.
# Exemplo:
# LUGEST_SHARED_STORAGE_ROOT=\\\\SERVIDOR\\LuGEST\\Ficheiros
# Se nao definires, o LuGEST usa uma pasta local em generated\\shared.

# Opcional: metadados e chaves para bloco fiscal/SAF-T(PT).
# Se nao definires nada, o LuGEST usa defaults internos e gera um par de chaves local
# apenas para cadeia documental interna. O numero de software certificado fica vazio/0
# enquanto nao existir certificacao AT real.
# LUGEST_SOFTWARE_CERT_NUMBER=
# LUGEST_SOFTWARE_PRODUCER_NAME=LuGEST
# LUGEST_SOFTWARE_PRODUCER_NIF=
# LUGEST_SOFTWARE_PRODUCT_ID=LuGEST
# LUGEST_SOFTWARE_PRODUCT_VERSION=2026.03
# LUGEST_HASH_CONTROL=1
# LUGEST_FISCAL_PRIVATE_KEY=generated/compliance/keys/lugest_fiscal_private.pem
# LUGEST_FISCAL_PUBLIC_KEY=generated/compliance/keys/lugest_fiscal_public.pem

# Nota: o desktop arranca sempre em Qt e exige ligacao ativa a MySQL.
# Usa de preferencia um utilizador MySQL dedicado em vez de `root`.
